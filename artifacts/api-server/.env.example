# Tailor Book API Server - Environment Configuration
#
# Copy to .env for local development. Keep real credentials out of git.

# Backend
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# MySQL
# Local development:
DATABASE_URL=mysql://tailorbook_app:change-me@localhost:3306/tailorbook

# LAN database access from this API server:
# DATABASE_URL=mysql://tailorbook_app:change-me@<mysql-host-lan-ip>:3306/tailorbook

# Individual variables are used only when DATABASE_URL is not set.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=tailorbook_app
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=tailorbook

# Authentication
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN=30d
