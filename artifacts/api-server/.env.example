# ============================================================
# Tailor Book API Server — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in real values.

# Server port
PORT=4000

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# MySQL Database
# ============================================================
# Option A: full connection URL (recommended)
DATABASE_URL=mysql://root:admin123@localhost:3306/tailorbook

# Option B: individual variables (used when DATABASE_URL is absent)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=admin123
# MYSQL_DATABASE=tailorbook

# ============================================================
# Authentication
# ============================================================
# IMPORTANT: Change JWT_SECRET in production!
JWT_SECRET=tailorbook-dev-secret-change-me-in-prod-please-use-openssl-rand
JWT_EXPIRES_IN=30d
