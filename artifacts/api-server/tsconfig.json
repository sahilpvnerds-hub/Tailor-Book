{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "paths": {
      "@workspace/db/*": ["../../lib/db/src/*"],
      "@workspace/api-zod/*": ["../../lib/api-zod/src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src"],
  "references": [
    {
      "path": "../../lib/db"
    },
    {
      "path": "../../lib/api-zod"
    }
  ]
}