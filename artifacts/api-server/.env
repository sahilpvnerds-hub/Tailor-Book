# ============================================================
# Tailor Book API Server — Environment Configuration
# ============================================================

# Server port
PORT=4000

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# MySQL Database
# ============================================================
DATABASE_URL=mysql://root:admin123@localhost:3306/tailorbook

# Individual variables (fallback if DATABASE_URL is not set)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=admin123
MYSQL_DATABASE=tailorbook

# ============================================================
# Authentication
# ============================================================
JWT_SECRET=tailorbook-dev-secret-change-me-in-prod-please-use-openssl-rand
JWT_EXPIRES_IN=30d

# ============================================================
# SMTP — Email delivery (Gmail)
# With these set, real OTP emails are sent and the mobile
# app stops returning the OTP in the response.
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anyalex813@gmail.com
SMTP_PASS=ffmf aoel abtf xmwm
SMTP_FROM=Tailor Book <anyalex813@gmail.com>
