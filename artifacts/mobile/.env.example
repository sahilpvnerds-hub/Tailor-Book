# Tailor Book — Mobile app environment
#
# This file is a TEMPLATE — copy it to `.env` and adjust for your environment.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the bundle at build time.
#
# For local development, you have three options:
#
#   1. Web preview (Expo Web):
#        EXPO_PUBLIC_API_URL=http://localhost:4000
#
#   2. iOS Simulator (Mac):
#        EXPO_PUBLIC_API_URL=http://localhost:4000
#
#   3. Android Emulator:
#        EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
#      (10.0.2.2 is the special alias for the host machine's localhost)
#
#   4. Physical device on the same Wi-Fi network:
#        EXPO_PUBLIC_API_URL=http://<your-LAN-IP>:4000
#      (find your IP with `ipconfig` on Windows or `ifconfig` on Mac/Linux)
#
EXPO_PUBLIC_API_URL=http://localhost:4000
